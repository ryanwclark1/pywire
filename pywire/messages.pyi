import enum

__all__: list[str]

class TransactionStatus(enum.Enum):
    """Transaction status reported by the backend in `ReadyForQuery`."""

    Idle = ...
    Transaction = ...
    Error = ...

class FieldDescription:
    """One column's metadata, inside a `RowDescription`."""

    name: str
    table_id: int
    column_id: int
    type_id: int
    type_size: int
    type_modifier: int
    format_code: int

    def __init__(
        self,
        name: str,
        *,
        table_id: int = 0,
        column_id: int = 0,
        type_id: int = 0,
        type_size: int = 0,
        type_modifier: int = 0,
        format_code: int = 0,
    ) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class Startup:
    """Frontend startup message. No type-tag byte."""

    protocol_number_major: int
    protocol_number_minor: int
    parameters: dict[str, str]

    def __init__(
        self,
        protocol_number_major: int = 3,
        protocol_number_minor: int = 0,
        parameters: dict[str, str] | None = None,
    ) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> Startup: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class Query:
    """Simple-query frontend message (`'Q'`)."""

    query: str

    def __init__(self, query: str) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> Query: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class Terminate:
    """Frontend connection-close message (`'X'`). Carries no payload."""

    def __init__(self) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> Terminate: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class ReadyForQuery:
    """Backend `'Z'` message: backend is ready for a new query."""

    status: TransactionStatus

    def __init__(self, status: TransactionStatus) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> ReadyForQuery: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class CommandComplete:
    """Backend `'C'` message: command-finished tag."""

    tag: str

    def __init__(self, tag: str) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> CommandComplete: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class RowDescription:
    """Backend `'T'` message: describes the columns of a result set."""

    fields: list[FieldDescription]

    def __init__(self, fields: list[FieldDescription] | None = None) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> RowDescription: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class DataRow:
    """Backend `'D'` message: one result-row payload as opaque bytes."""

    field_count: int
    data: bytes

    def __init__(self, field_count: int, data: bytes) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> DataRow: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class ErrorResponse:
    """Backend `'E'` message: PostgreSQL error-field list.

    Each entry is a `(tag_byte, value)` pair. For a structured view,
    convert these into a `pywire.errors.ErrorInfo`.
    """

    fields: list[tuple[int, str]]

    def __init__(self, fields: list[tuple[int, str]] | None = None) -> None: ...
    def encode(self) -> bytes: ...
    @classmethod
    def decode(cls, data: bytes) -> ErrorResponse: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
